//Crear controlador


package com.example.api.controller;

import com.example.api.service.HashService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.HashMap;
import java.util.Map;

@RestController
@RequestMapping("/api/hash")
public class HashController {

    @Autowired
    private HashService hashService;

    @GetMapping
    public ResponseEntity<?> generateHash(
            @RequestParam(required = false) String algorithm,
            @RequestParam(required = false) String text) {

        long startTime = System.nanoTime();

        // Validaciones
        if (algorithm == null || text == null) {
            return buildErrorResponse(
                    "Faltan parámetros obligatorios",
                    HttpStatus.BAD_REQUEST,
                    startTime
            );
        }

        if (!algorithm.equalsIgnoreCase("md5")) {
            return buildErrorResponse(
                    "Algoritmo no soportado",
                    HttpStatus.BAD_REQUEST,
                    startTime
            );
        }

        String hash = hashService.generateMD5(text);

        long responseTime = System.nanoTime() - startTime;

        // Construcción de respuesta
        Map<String, Object> response = new HashMap<>();

        Map<String, Object> header = new HashMap<>();
        header.put("api_name", "UA4 API");
        header.put("api_version", "1.0.0");
        header.put("api_user", "guest");
        header.put("api_endpoint", "/api/hash");
        header.put("http_request_method", "GET");

        Map<String, String> params = new HashMap<>();
        params.put("algorithm", algorithm);
        params.put("text", text);

        header.put("http_request_parameters", params);
        header.put("http_response_status", 200);
        header.put("http_response_message", "OK");
        header.put("response_time", responseTime);

        Map<String, Object> body = new HashMap<>();
        body.put("algorithm", algorithm);
        body.put("text", text);
        body.put("hash", hash);

        response.put("header", header);
        response.put("body", body);

        return ResponseEntity.ok(response);
    }

    private ResponseEntity<?> buildErrorResponse(String message,
                                                 HttpStatus status,
                                                 long startTime) {

        long responseTime = System.nanoTime() - startTime;

        Map<String, Object> response = new HashMap<>();

        Map<String, Object> header = new HashMap<>();
        header.put("api_name", "UA4 API");
        header.put("api_version", "1.0.0");
        header.put("api_user", "guest");
        header.put("api_endpoint", "/api/hash");
        header.put("http_request_method", "GET");
        header.put("http_response_status", status.value());
        header.put("http_response_message", message);
        header.put("response_time", responseTime);

        response.put("header", header);
        response.put("body", null);

        return ResponseEntity.status(status).body(response);
    }
}
